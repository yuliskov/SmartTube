<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/vot_token_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:textColor="@color/dialog_text_color"
        android:textSize="14sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:maxHeight="160dp">

        <EditText
            android:id="@+id/vot_token_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/dialog_text_color"
            android:gravity="top|start"
            android:imeOptions="actionDone"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="3"
            android:scrollbars="vertical"
            android:textColor="@color/dialog_text_color"
            android:textColorHint="@color/white_50"
            android:textCursorDrawable="@null" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/vot_token_paste"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:focusable="true"
            android:text="@string/vot_paste_clipboard" />

        <Button
            android:id="@+id/vot_token_clear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:focusable="true"
            android:text="@string/vot_clear_token" />
    </LinearLayout>
</LinearLayout>
